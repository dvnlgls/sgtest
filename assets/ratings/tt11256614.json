{"details": [{"n": "The Ambassador's Daughter", "r": 6.0, "v": 1592, "y": "2019", "ec": 48}], "ratings": [{"r": 7.8, "v": 115, "en": "1.Bölüm", "eid": "tt11399038", "eno": 1, "sno": 1}, {"r": 8.7, "v": 81, "en": "Efem ala boyanmis, kaniyor her yani.", "eid": "tt11444058", "eno": 2, "sno": 1}, {"r": 8.7, "v": 77, "en": "Adini anmayacagima Nasuh Tövbesi olsun mu?", "eid": "tt11444060", "eno": 3, "sno": 1}, {"r": 8.8, "v": 68, "en": "Bana memleket olmadin, kizima ol.", "eid": "tt11528728", "eno": 4, "sno": 1}, {"r": 8.8, "v": 61, "en": "Biz o enkazin altinda kaldik.", "eid": "tt11611104", "eno": 5, "sno": 1}, {"r": 8.9, "v": 58, "en": "Ben sana suçluyken bile inandim.", "eid": "tt11650138", "eno": 6, "sno": 1}, {"r": 8.5, "v": 57, "en": "Arkadaslar uykularda uyansin.", "eid": "tt11690056", "eno": 7, "sno": 1}, {"r": 8.7, "v": 55, "en": "Bana niye mektup yazmadin?", "eid": "tt11728420", "eno": 8, "sno": 1}, {"r": 8.8, "v": 55, "en": "Kimse sana inanmak istemez.", "eid": "tt11771060", "eno": 9, "sno": 1}, {"r": 8.8, "v": 55, "en": "Sen mi bana kiydin, ben mi sana kiydim?", "eid": "tt11812628", "eno": 10, "sno": 1}, {"r": 8.9, "v": 56, "en": "Delirme, delirince geçmiyor.", "eid": "tt11854000", "eno": 11, "sno": 1}, {"r": 8.9, "v": 51, "en": "Uzun ince bir yoldayim", "eid": "tt11902936", "eno": 12, "sno": 1}, {"r": 8.5, "v": 49, "en": "Ben senin katilin olmusum", "eid": "tt11945354", "eno": 13, "sno": 1}, {"r": 8.6, "v": 48, "en": "Kizinin elinden tut", "eid": "tt11981198", "eno": 14, "sno": 1}, {"r": 8.5, "v": 51, "en": "Öfkeli bir çocuga daha fazla eyvallahim yok", "eid": "tt12038320", "eno": 15, "sno": 1}, {"r": 8.6, "v": 48, "en": "Sen gidersen ben çok kötü bir adam olurum.", "eid": "tt12476282", "eno": 16, "sno": 1}, {"r": 8.7, "v": 53, "en": "Bu destan denizin dibinde basladi, orada bitmez ki.", "eid": "tt12528906", "eno": 17, "sno": 1}, {"r": 8.3, "v": 55, "en": "Sana canimi veririm, adini vermem.", "eid": "tt13010822", "eno": 1, "sno": 2}, {"r": 8.7, "v": 42, "en": "Senin yaninda yara mi olacak, benim yaninda yar mi?", "eid": "tt13051948", "eno": 2, "sno": 2}, {"r": 8.5, "v": 42, "en": "Ben ganimet degilim.", "eid": "tt13093964", "eno": 3, "sno": 2}, {"r": 8.9, "v": 39, "en": "Bana kizim yeter.", "eid": "tt13142350", "eno": 4, "sno": 2}, {"r": 9.0, "v": 39, "en": "Sensizlik yakiyor, onsuzluk öldürür.", "eid": "tt13229002", "eno": 5, "sno": 2}, {"r": 8.9, "v": 36, "en": "Helalim sensin benim.", "eid": "tt13229024", "eno": 6, "sno": 2}, {"r": 8.5, "v": 37, "en": "Senin acin, senin hakkin.", "eid": "tt13269462", "eno": 7, "sno": 2}, {"r": 8.5, "v": 38, "en": "Destanlarda kavusamazsin ama asla ayrilmazsin.", "eid": "tt13327528", "eno": 8, "sno": 2}, {"r": 8.5, "v": 35, "en": "Alacakus olan bendim, sen niye uçtun?", "eid": "tt13376564", "eno": 9, "sno": 2}, {"r": 8.9, "v": 34, "en": "Yolun sonunda sen varsin.", "eid": "tt13403060", "eno": 10, "sno": 2}, {"r": 9.2, "v": 24, "en": "Baba omzu diye bir yer var.", "eid": "tt13450512", "eno": 11, "sno": 2}, {"r": 9.4, "v": 23, "en": "Allah'im emri, peygamberin kavliyle...", "eid": "tt13508578", "eno": 12, "sno": 2}, {"r": 8.7, "v": 24, "en": "Benim memleketim yarasinda çiçek açtirir.", "eid": "tt13546380", "eno": 13, "sno": 2}, {"r": 8.3, "v": 26, "en": "Beni yakmamayi ögrenecek misin?", "eid": "tt13587102", "eno": 14, "sno": 2}, {"r": 9.4, "v": 27, "en": "Pamuk oldugum günleri çok özledim", "eid": "tt13622436", "eno": 15, "sno": 2}, {"r": 8.4, "v": 25, "en": "Kizim bana bir kere baba desin.", "eid": "tt13670648", "eno": 16, "sno": 2}, {"r": 8.1, "v": 34, "en": "Eyvallah Sefirin Kizi.", "eid": "tt13705352", "eno": 17, "sno": 2}, {"r": 7.6, "v": 32, "en": "Senin için Sancar Efe", "eid": "tt13778448", "eno": 18, "sno": 2}, {"r": 7.1, "v": 53, "en": "Ates idim küle döndüm.", "eid": "tt13862914", "eno": 19, "sno": 2}, {"r": 8.1, "v": 41, "en": "Gitmek mi zor kalmak mi?", "eid": "tt13911458", "eno": 20, "sno": 2}, {"r": 7.4, "v": 50, "en": "Mavi", "eid": "tt13945408", "eno": 21, "sno": 2}, {"r": 7.9, "v": 39, "en": "Sana ne oldu?", "eid": "tt13989110", "eno": 22, "sno": 2}, {"r": 8.3, "v": 42, "en": "Sana ihtiyacim var.", "eid": "tt14043308", "eno": 23, "sno": 2}, {"r": 8.4, "v": 35, "en": "Ben hala anneyim.", "eid": "tt14089340", "eno": 24, "sno": 2}, {"r": 8.5, "v": 32, "en": "Güven bana. Basaracagiz.", "eid": "tt14128016", "eno": 25, "sno": 2}, {"r": 9.0, "v": 26, "en": "Geçmisin günahlari bugünün katilidir.", "eid": "tt14183232", "eno": 26, "sno": 2}, {"r": 8.7, "v": 26, "en": "Kosulsuz seversen, inanirsin...", "eid": "tt14227108", "eno": 27, "sno": 2}, {"r": 9.0, "v": 19, "en": "Güven sevgiden bile önce gelir", "eid": "tt14278732", "eno": 28, "sno": 2}, {"r": 8.6, "v": 24, "en": "Gerçek sevgi her zorlugun üstesinden gelir.", "eid": "tt14321744", "eno": 29, "sno": 2}, {"r": 8.4, "v": 15, "en": "Ask sahip olmak midir ait olmak mi?", "eid": "tt14381550", "eno": 30, "sno": 2}]}
