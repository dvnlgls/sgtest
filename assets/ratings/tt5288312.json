{"details": [{"n": "Skam", "r": 8.6, "v": 28976, "y": "2015", "ec": 43}], "ratings": [{"r": 7.0, "v": 564, "en": "Du ser ut som en slut", "eid": "tt5534712", "eno": 1, "sno": 1}, {"r": 7.0, "v": 420, "en": "Jonas, dette er helt dust", "eid": "tt5534724", "eno": 2, "sno": 1}, {"r": 7.4, "v": 409, "en": "Vi er de største loserne på skolen", "eid": "tt5571508", "eno": 3, "sno": 1}, {"r": 7.4, "v": 395, "en": "Go for it din lille slut", "eid": "tt5571514", "eno": 4, "sno": 1}, {"r": 7.5, "v": 381, "en": "Hva er det som gjør deg kåt?", "eid": "tt5571526", "eno": 5, "sno": 1}, {"r": 7.6, "v": 392, "en": "Man vet når gutter lyver", "eid": "tt5571528", "eno": 6, "sno": 1}, {"r": 7.7, "v": 382, "en": "Tenker alltid det er meg det er noe galt med", "eid": "tt5571532", "eno": 7, "sno": 1}, {"r": 7.7, "v": 382, "en": "Hele skolen hater meg", "eid": "tt5571538", "eno": 8, "sno": 1}, {"r": 7.9, "v": 378, "en": "Man er det man gjør", "eid": "tt5571544", "eno": 9, "sno": 1}, {"r": 8.1, "v": 397, "en": "Jeg tenker at du har blitt helt psyko", "eid": "tt5571548", "eno": 10, "sno": 1}, {"r": 8.3, "v": 424, "en": "Et jævlig dumt valg", "eid": "tt5571550", "eno": 11, "sno": 1}, {"r": 7.6, "v": 399, "en": "Om du bare hadde holdt det du lovet", "eid": "tt5571556", "eno": 1, "sno": 2}, {"r": 7.7, "v": 379, "en": "Du lyver til en venninne og skylder på meg", "eid": "tt5571562", "eno": 2, "sno": 2}, {"r": 8.2, "v": 439, "en": "Er det noe du skjuler for oss?", "eid": "tt5571564", "eno": 3, "sno": 2}, {"r": 7.3, "v": 393, "en": "Jeg visste det var noe rart med henne", "eid": "tt5771348", "eno": 4, "sno": 2}, {"r": 7.9, "v": 404, "en": "Jeg er i hvert fall ikke sjalu", "eid": "tt5771352", "eno": 5, "sno": 2}, {"r": 7.5, "v": 378, "en": "Jeg vil ikke bli beskytta", "eid": "tt5771356", "eno": 6, "sno": 2}, {"r": 7.5, "v": 371, "en": "Noora, du trenger pikk", "eid": "tt5771358", "eno": 7, "sno": 2}, {"r": 7.7, "v": 382, "en": "Du tenker bare på William", "eid": "tt5771362", "eno": 8, "sno": 2}, {"r": 7.7, "v": 366, "en": "Jeg savner deg så jævlig", "eid": "tt5771364", "eno": 9, "sno": 2}, {"r": 8.3, "v": 424, "en": "Jeg skal forklare alt", "eid": "tt5771366", "eno": 10, "sno": 2}, {"r": 7.9, "v": 388, "en": "Husker du seriøst ingenting?", "eid": "tt5771368", "eno": 11, "sno": 2}, {"r": 7.8, "v": 397, "en": "Vil du flytte sammen med meg?", "eid": "tt5779334", "eno": 12, "sno": 2}, {"r": 8.5, "v": 666, "en": "Lykke til, Isak", "eid": "tt5934500", "eno": 1, "sno": 3}, {"r": 8.5, "v": 629, "en": "Du er over 18, sant?", "eid": "tt6123960", "eno": 2, "sno": 3}, {"r": 8.7, "v": 633, "en": "Nå bånder dere i overkant mye", "eid": "tt6123962", "eno": 3, "sno": 3}, {"r": 8.8, "v": 679, "en": "Keen på å bade", "eid": "tt6123964", "eno": 4, "sno": 3}, {"r": 8.9, "v": 680, "en": "Samme tid et helt annet sted", "eid": "tt6123968", "eno": 5, "sno": 3}, {"r": 8.7, "v": 616, "en": "Escobar Season", "eid": "tt6123972", "eno": 6, "sno": 3}, {"r": 8.9, "v": 696, "en": "Er du homo?", "eid": "tt6123978", "eno": 7, "sno": 3}, {"r": 9.0, "v": 692, "en": "Mannen i mitt liv", "eid": "tt6123982", "eno": 8, "sno": 3}, {"r": 9.4, "v": 947, "en": "Det går over", "eid": "tt6123984", "eno": 9, "sno": 3}, {"r": 9.1, "v": 723, "en": "Minutt for minutt", "eid": "tt6123986", "eno": 10, "sno": 3}, {"r": 7.7, "v": 300, "en": "Du hater å henge med oss", "eid": "tt6678126", "eno": 1, "sno": 4}, {"r": 7.5, "v": 264, "en": "Jeg er gutt, jeg får ikke hat", "eid": "tt6754692", "eno": 2, "sno": 4}, {"r": 7.5, "v": 244, "en": "Hva mener du om drikking?", "eid": "tt6754696", "eno": 3, "sno": 4}, {"r": 7.9, "v": 263, "en": "Allah hadde digget deg", "eid": "tt6754700", "eno": 4, "sno": 4}, {"r": 8.3, "v": 289, "en": "Hvis du er trist er jeg trist", "eid": "tt6754784", "eno": 5, "sno": 4}, {"r": 7.3, "v": 238, "en": "Har du en dårlig dag?", "eid": "tt6754794", "eno": 6, "sno": 4}, {"r": 7.6, "v": 229, "en": "Vi må stå sammen", "eid": "tt6754814", "eno": 7, "sno": 4}, {"r": 8.3, "v": 283, "en": "De største loserne på skolen", "eid": "tt6754836", "eno": 8, "sno": 4}, {"r": 7.7, "v": 240, "en": "Livet smiler", "eid": "tt6754838", "eno": 9, "sno": 4}, {"r": 9.0, "v": 494, "en": "Takk for alt", "eid": "tt6754842", "eno": 10, "sno": 4}]}
