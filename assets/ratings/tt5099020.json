{"details": [{"n": "Aranyélet", "r": 8.7, "v": 7404, "y": "2015", "ec": 24}], "ratings": [{"r": 8.0, "v": 185, "en": "Még pár éved van, aztán nem lesz több móka", "eid": "tt5177922", "eno": 1, "sno": 1}, {"r": 8.0, "v": 159, "en": "Nyugtató, taurin", "eid": "tt5196582", "eno": 2, "sno": 1}, {"r": 7.9, "v": 149, "en": "Ropognak a húszasok", "eid": "tt5210562", "eno": 3, "sno": 1}, {"r": 8.2, "v": 143, "en": "Beléptem álmaim kapuin", "eid": "tt5225362", "eno": 4, "sno": 1}, {"r": 8.4, "v": 139, "en": "Hiába minden próbálkozás", "eid": "tt5252332", "eno": 5, "sno": 1}, {"r": 9.0, "v": 149, "en": "Az iskola nem az életre nevel", "eid": "tt5252362", "eno": 6, "sno": 1}, {"r": 9.0, "v": 141, "en": "Na, ki az, aki hazudik?", "eid": "tt5292856", "eno": 7, "sno": 1}, {"r": 9.0, "v": 147, "en": "Most már látod, hogy mi van itt", "eid": "tt5292896", "eno": 8, "sno": 1}, {"r": 8.2, "v": 144, "en": "Összetett célok = tartós siker", "eid": "tt6201938", "eno": 1, "sno": 2}, {"r": 8.1, "v": 133, "en": "A helyzethez igazítsd a taktikádat", "eid": "tt6230716", "eno": 2, "sno": 2}, {"r": 8.4, "v": 131, "en": "Az okos kockázatvállalás biztonságot nyújt", "eid": "tt6241902", "eno": 3, "sno": 2}, {"r": 8.5, "v": 125, "en": "A sikeres üzletben mindkét fél gyoz", "eid": "tt6241908", "eno": 4, "sno": 2}, {"r": 9.6, "v": 245, "en": "A képesség nem garancia az eredményességre", "eid": "tt6241910", "eno": 5, "sno": 2}, {"r": 8.5, "v": 121, "en": "Értsd, amit csinálsz - csináld, amihez értesz", "eid": "tt6241912", "eno": 6, "sno": 2}, {"r": 9.0, "v": 135, "en": "Egy nagy siker minden kudarcot ellensúlyoz", "eid": "tt6241916", "eno": 7, "sno": 2}, {"r": 8.2, "v": 115, "en": "Jól megválasztott cél vezet sikerhez", "eid": "tt6241918", "eno": 8, "sno": 2}, {"r": 8.3, "v": 179, "en": "Semmi sem számít, csak az, hogy ki vagy", "eid": "tt7180814", "eno": 1, "sno": 3}, {"r": 8.1, "v": 122, "en": "A rock and roll az nem egy tánc", "eid": "tt8751878", "eno": 2, "sno": 3}, {"r": 8.3, "v": 102, "en": "Egyedül fél ember vagy", "eid": "tt8751940", "eno": 3, "sno": 3}, {"r": 8.5, "v": 103, "en": "Vakfolt", "eid": "tt8751954", "eno": 4, "sno": 3}, {"r": 8.0, "v": 95, "en": "Jégkocka", "eid": "tt8751960", "eno": 5, "sno": 3}, {"r": 8.2, "v": 86, "en": "Csak a hülyék folytatják a palávert, ha tudják, utána jön a pofon", "eid": "tt8751964", "eno": 6, "sno": 3}, {"r": 8.3, "v": 104, "en": "Dolgozni rémes", "eid": "tt8751968", "eno": 7, "sno": 3}, {"r": 7.2, "v": 98, "en": "Karma", "eid": "tt8751972", "eno": 8, "sno": 3}]}
